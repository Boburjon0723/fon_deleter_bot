# Nusxa: mahalliy ishlatish uchun `.env` yarating (`.env` gitga kiritilmaydi)
#   copy .env.example .env
# Railway: Variables bo‘limida shu nomlar bilan qo‘shing (fayl yuklash shart emas)

TELEGRAM_BOT_TOKEN=
# draft=tez (standart) | normal | high | max
BOT_QUALITY=draft
BOT_DEVICE=cpu
# Chiqish kvadrati px (768 tezroq; 1024 sifat)
BOT_CANVAS_SIDE=768
